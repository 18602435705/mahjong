{
  "name": "@react-mono/mahjong-core",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm -C ../.. --filter mahjong-app exec tsc -p ../../packages/mahjong-core/tsconfig.build.json",
    "dev": "pnpm -C ../.. --filter mahjong-app exec tsc -p ../../packages/mahjong-core/tsconfig.build.json --watch",
    "test": "echo \"No tests yet for mahjong-core\"",
    "lint": "echo \"No lint step for mahjong-core\""
  }
}
